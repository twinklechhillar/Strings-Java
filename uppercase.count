class Main {
    public static void main(String[] args) {
        String s = "heLLo";
        int count =0;
        for(int i =0; i<s.length(); i++){
            char ch = s.charAt(i);
            if( ch>='A' && ch<='Z'){
                count++;
            }
        }
        
        System.out.println("upper case=" +count);
    }
}
